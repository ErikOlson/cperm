{
  "name": "strict-secrets",
  "description": "Deny access to secrets, credentials, and sensitive files",
  "version": "0.1.0",
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/credentials.json)",
      "Bash(sudo:*)",
      "Bash(su:*)"
    ]
  }
}
