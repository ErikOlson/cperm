{
  "name": "base",
  "description": "Core file and search operations — the foundation for any project",
  "version": "0.1.0",
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "TodoWrite",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(echo:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(diff:*)",
      "Bash(chmod:*)",
      "Bash(lsof:*)"
    ]
  }
}
